# ~/.zshenv
# Always loaded. Keep fast and side-effect free.

# Core tools
export EDITOR="zed --wait"
export PAGER="bat"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

export HOMEBREW_NO_ENV_HINTS=1
export SHELL_SESSIONS_DISABLE=1

# XDG dirs
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_BIN_HOME="$HOME/.local/bin"
export XDG_RUNTIME_DIR="$HOME/.local/run"

# Paths to keep $HOME clean
export GOPATH="$XDG_DATA_HOME/go"
export GOBIN="$XDG_BIN_HOME"
export CARGO_HOME="$XDG_DATA_HOME/cargo"
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"
export HISTFILE="$XDG_STATE_HOME/zsh/history"
export NPM_CONFIG_INIT_MODULE="$XDG_CONFIG_HOME/npm/config/npm-init.js"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
# export GNUPGHOME="$XDG_DATA_HOME/gnupg" -- check gpgconf --list-dirs to see what sockets reference this
{{ if .cloudInstall }}
export ANSIBLE_HOME="$XDG_DATA_HOME/ansible"
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"
export MINIKUBE_HOME="$XDG_DATA_HOME"/minikube
{{ end }}

# UI & color
export CLICOLOR=1
export LS_COLORS='di=1;34:ln=1;35:so=1;32:pi=1;33:ex=1;31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43'

# Homebrew prefix (modern macOS assumption)
export HOMEBREW_PREFIX="/opt/homebrew"

# PATH construction (exact priority order, de-duplicated)
typeset -U path

path=(
  "$HOMEBREW_PREFIX/bin"
  "$HOMEBREW_PREFIX/sbin"
  /usr/local/bin
  /usr/bin
  /bin
  /usr/sbin
  /sbin
)

[[ -d "$HOME/.lmstudio/bin" ]] && path+=("$HOME/.lmstudio/bin")
[[ -d "$HOME/.local/bin"   ]] && path+=("$HOME/.local/bin")
[[ -d "$HOME/.bun/bin"     ]] && path+=("$HOME/.bun/bin")